// firestore.rules — PADQ v3
// ═══════════════════════════════════════════════════════════
// Deploy:  firebase deploy --only firestore:rules
//
// WHAT'S NEW IN v3:
//  • lastActiveAt field stamped on every host write (TTL clock)
//  • Firestore TTL auto-deletes sessions idle for 30+ minutes
//    (configured in Firebase Console — see SETUP.md)
//  • Firestore TTL bypasses security rules entirely — no change
//    needed here for TTL deletes to work
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sessions/{sessionId} {

      // ── READ: anyone with the session ID can read ──────────
      allow read: if true;

      // ── CREATE: requires a non-empty hostToken ─────────────
      allow create: if request.resource.data.hostToken is string
                    && request.resource.data.hostToken.size() > 0;

      // ── UPDATE: only the original host can mutate.
      //    The incoming write must carry the same hostToken
      //    already stored. lastActiveAt is always included — fine.
      allow update: if request.resource.data.hostToken == resource.data.hostToken;

      // ── DELETE: client-initiated deletes (e.g. hard reset).
      //    TTL-initiated deletes bypass rules entirely — they always succeed.
      allow delete: if request.resource.data.hostToken == resource.data.hostToken;

      // ── History subcollection ──────────────────────────────
      match /history/{entryId} {
        allow read: if true;
        allow create: if get(/databases/$(database)/documents/sessions/$(sessionId))
                         .data.hostToken == request.resource.data.hostToken;
        allow update, delete: if false;
      }
    }
  }
}
