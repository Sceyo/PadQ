rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.resource.data.hostToken == resource.data.hostToken;
      allow delete: if request.resource.data.hostToken == resource.data.hostToken;

      match /history/{entry} {
        allow read: if true;
        allow write: if request.resource.data.hostToken ==
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostToken;
      }
    }
  }
}
